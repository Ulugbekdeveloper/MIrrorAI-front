# Local dev config. Not committed (see .gitignore).

# ── Backend ────────────────────────────────────────────────────────────
# iOS simulator + Mac backend: localhost works.
# Android emulator: use http://10.0.2.2:3000 instead.
# Physical device on same Wi-Fi: use your Mac's LAN IP, e.g. http://192.168.1.42:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_TIMEOUT_MS=30000

